generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  aluno
  gestor
  admin
}

enum UserStatus {
  pending
  active
  blocked
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role       @default(aluno)
  status       UserStatus @default(active)
  onboardedAt  DateTime?
  targetCertSlug  String?
  experienceLevel String?
  dailyGoalMin    Int?
  reviews      ReviewState[]
  attempts     Attempt[]
  examSessions ExamSession[]
  companies    Company[]
  installToken InstallToken?
  createdAt    DateTime @default(now())
}

// Catálogo de skills/plugins do Claude Code distribuídos para o time.
// O banco é a fonte da verdade; o repositório git servido por git-http-backend
// é materializado a partir daqui (ver src/marketplace/materialize.ts).
model Plugin {
  id          String        @id @default(uuid())
  slug        String        @unique // kebab-case; vira /plugin install <slug>@colaborativa
  displayName String
  description String
  version     String        @default("0.1.0") // semver; bump = nova versão publicada
  category    String?
  keywords    String[]
  author      String?
  published   Boolean       @default(false) // só publicados entram no marketplace.json
  skills      PluginSkill[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PluginSkill {
  id        String @id @default(uuid())
  plugin    Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  pluginId  String
  slug      String // pasta skills/<slug>/
  skillMd   String // conteúdo do SKILL.md (frontmatter + corpo)
  files     Json   @default("[]") // arquivos extras: [{ path, content }] (ex: references/x.md)

  @@unique([pluginId, slug])
}

// Token por usuário usado no path da URL git para o acesso restrito ao marketplace.
model InstallToken {
  id         String    @id @default(uuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String    @unique
  token      String    @unique
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
}

// Estado persistido do jogo "Startup Tycoon de IA": uma empresa por usuário+cert.
// As métricas derivadas (nível, qualidade, usuários) são calculadas on-read a
// partir de Attempt/ReviewState; aqui guardamos só o que precisa persistir.
model Company {
  id              String   @id @default(uuid())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  certSlug        String
  name            String
  credits         Int      @default(0)
  tiers           Json     @default("{}")
  mrr             Int      @default(0)
  valuation       Int      @default(0)
  lastCollectedAt DateTime @default(now())
  createdAt       DateTime @default(now())

  @@unique([userId, certSlug])
}

model Certification {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String
  version     Int      @default(1)
  level       String   @default("iniciante") // iniciante | intermediario | avancado | comercial
  modules     Module[]
  createdAt   DateTime @default(now())
}

model Module {
  id      String        @id @default(uuid())
  cert    Certification @relation(fields: [certId], references: [id], onDelete: Cascade)
  certId  String
  order   Int
  title   String
  lessons Lesson[]
}

model Lesson {
  id         String @id @default(uuid())
  module     Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  moduleId   String
  order      Int
  title      String
  readingMd  String
  flashcards Flashcard[]
  questions  Question[]
  labs       Lab[]
}

model Lab {
  id          String   @id @default(uuid())
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId    String
  title       String
  promptMd    String
  rubric      String[]
  modelAnswer String
  createdAt   DateTime @default(now())
}

model Flashcard {
  id        String   @id @default(uuid())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId  String
  front     String
  back      String
  tags      String[]
  reviews   ReviewState[]
  createdAt DateTime @default(now())
}

model Question {
  id           String   @id @default(uuid())
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId     String
  prompt       String
  options      String[]
  correctIndex Int
  explanation  String
  difficulty   Int      @default(1)
  tags         String[]
  attempts     Attempt[]
  createdAt    DateTime @default(now())
}

model ReviewState {
  id           String    @id @default(uuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  flashcard    Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
  flashcardId  String
  ease         Float     @default(2.5)
  intervalDays Int       @default(0)
  reps         Int       @default(0)
  lapses       Int       @default(0)
  dueAt        DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, flashcardId])
}

model Attempt {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId  String
  chosenIndex Int
  correct     Boolean
  createdAt   DateTime @default(now())
}

model ExamSession {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  certId      String
  questionIds String[]
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  total       Int       @default(0)
  correct     Int       @default(0)
  scorePct    Float     @default(0)
}
